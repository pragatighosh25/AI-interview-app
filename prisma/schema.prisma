generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  name        String?
  email       String      @unique
  password    String
  createdAt   DateTime    @default(now())

  interviews  Interview[]  
}

model Interview {
  id        String   @id @default(cuid())
  userId    String
  score     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
